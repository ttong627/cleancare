rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // -----------------------------------------------------------------
    // 1. 공통 권한 확인 함수 (RBAC - Role Based Access Control)
    // -----------------------------------------------------------------
    
    // 현재 요청을 보낸 사용자의 권한(Role)을 users 컬렉션에서 가져옴
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function isMaster() {
      return request.auth != null && getUserData().role == 'MASTER';
    }
    
    function isAdmin() {
      return request.auth != null && getUserData().role == 'ADMIN';
    }
    
    function isWorker() {
      return request.auth != null && getUserData().role == 'WORKER';
    }
    
    function isOfficial() {
      return request.auth != null && getUserData().role == 'OFFICIAL';
    }

    // 마스터와 관리담당자는 내부 관리자로 취급
    function isInternalManager() {
      return isMaster() || isAdmin();
    }

    // -----------------------------------------------------------------
    // 2. 사용자 (Users) 컬렉션 규칙
    // -----------------------------------------------------------------
    match /users/{userId} {
      // 본인 정보는 누구나 읽기 가능, 마스터/관리자는 모든 작업자 읽기 가능
      allow read: if request.auth.uid == userId || isInternalManager();
      
      // 사용자 생성/수정/삭제는 오직 마스터(MASTER)만 가능 (최고 보안)
      // 단, 관리담당자(ADMIN)는 현장실무자(WORKER)만 생성 가능하도록 제한
      allow create, update, delete: if isMaster() || 
        (isAdmin() && request.resource.data.role == 'WORKER');
    }

    // -----------------------------------------------------------------
    // 3. 현장 프로젝트 (Projects) 컬렉션 규칙
    // -----------------------------------------------------------------
    match /projects/{projectId} {
      // [읽기 권한]
      // 1. 마스터/관리자는 모든 현장 읽기 가능
      // 2. 현장실무자는 "자신이 배정된(workerId)" 현장만 읽기 가능
      // 3. 담당공무원은 "자신의 담당 지역(region)" 현장만 읽기 가능
      allow read: if isInternalManager() || 
                     (isWorker() && resource.data.workerId == request.auth.uid) ||
                     (isOfficial() && resource.data.region == getUserData().assignedRegion);
      
      // [생성 및 삭제 권한]
      // 마스터와 관리담당자만 현장을 새롭게 배정하거나 취소할 수 있음
      allow create, delete: if isInternalManager();

      // [수정 권한 분리]
      // 1. 마스터/관리자: 모든 필드 수정 가능 (정산, 팩스, 상태 등)
      // 2. 현장실무자: 오직 상태(status), 사진(Images) 필드만 업데이트 가능. 금액(price) 등은 조작 불가.
      // 3. 공무원: 수정 절대 불가 (View-Only)
      allow update: if isInternalManager() ||
        (
          isWorker() &&
          resource.data.workerId == request.auth.uid &&
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(['price', 'invoiceIssued', 'faxSent', 'workerId', 'region'])
        );
    }

    // -----------------------------------------------------------------
    // 4. 배정 일정 (Assignments) 컬렉션 규칙
    // -----------------------------------------------------------------
    match /assignments/{assignmentId} {
      // 마스터/관리자: 전체 CRUD
      // 현장실무자: 본인에게 배정된 일정만 읽기 가능 (수정 불가)
      allow read: if isInternalManager() ||
                     (isWorker() && resource.data.workerId == request.auth.uid);
      allow create, update, delete: if isInternalManager();
    }

    // -----------------------------------------------------------------
    // 5. 작업자 (Workers) 컬렉션 규칙
    // -----------------------------------------------------------------
    match /workers/{workerId} {
      // 마스터/관리자: 전체 CRUD
      // 현장실무자: 본인 문서만 읽기 및 위치(lastLocation) 필드만 수정 가능
      allow read: if isInternalManager() ||
                     (isWorker() && workerId == request.auth.uid);
      allow create, delete: if isInternalManager();
      allow update: if isInternalManager() ||
        (
          isWorker() &&
          workerId == request.auth.uid &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['lastLocation', 'status'])
        );
    }

    // -----------------------------------------------------------------
    // 6. 거래처 (Clients) 컬렉션 규칙
    // -----------------------------------------------------------------
    match /clients/{clientId} {
      // 거래처 정보는 내부 관리자만 접근 가능 (사업자번호 등 민감 정보 포함)
      allow read, write: if isInternalManager();
    }

    // -----------------------------------------------------------------
    // 7. 세금계산서 (Invoices) 컬렉션 규칙
    // -----------------------------------------------------------------
    match /invoices/{invoiceId} {
      // 마스터/관리자: 전체 읽기/생성 가능
      // 취소(삭제)는 마스터만 가능
      allow read, create: if isInternalManager();
      allow update, delete: if isMaster();
    }
  }
}
